# ─── Database (Supabase PostgreSQL) ──────────────────────────────────────────
# Get both from: Supabase Dashboard → Settings → Database → Connection string
# Use "Transaction" mode URL for DATABASE_URL and "Session" mode for DIRECT_URL
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"

# ─── JWT Authentication ───────────────────────────────────────────────────────
# Generate a strong random secret: run `node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"`
JWT_SECRET="your-very-long-random-secret-key-minimum-64-characters"
JWT_EXPIRES_IN="7d"

# ─── QR Token Security ────────────────────────────────────────────────────────
# Any long random string — used to sign QR HMAC tokens
QR_SECRET_SALT="your-qr-secret-salt-change-this-in-production"

# ─── Supabase (for file uploads from backend) ─────────────────────────────────
# Get from: Supabase Dashboard → Settings → API
SUPABASE_URL="https://[YOUR-PROJECT-REF].supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
